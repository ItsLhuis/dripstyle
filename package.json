{
  "name": "dripstyle",
  "version": "1.0.0",
  "private": true,
  "description": "Type-safe React Native styling engine",
  "homepage": "https://github.com/ItsLhuis/dripstyle#readme",
  "repository": {
    "type": "git",
    "url": "https://github.com/ItsLhuis/dripstyle"
  },
  "workspaces": [
    "packages/*",
    "example"
  ],
  "license": "MIT",
  "author": "ItsLhuis",
  "scripts": {
    "prepare": "husky",
    "build": "turbo run build",
    "dev": "turbo run dev",
    "start": "turbo run start",
    "lint": "turbo run lint",
    "lint:root": "eslint .",
    "lint:fix": "turbo run lint:fix",
    "lint:fix:root": "eslint . --fix",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "typecheck": "turbo run typecheck"
  },
  "engines": {
    "node": ">=24.0.0",
    "pnpm": ">=10.23.0"
  },
  "packageManager": "pnpm@10.23.0",
  "pnpm": {
    "overrides": {
      "typescript": "^5.9.3"
    }
  },
  "devDependencies": {
    "@commitlint/cli": "^20.4.2",
    "chalk": "^5.6.2",
    "tsx": "^4.21.0",
    "@commitlint/config-conventional": "^20.4.2",
    "@eslint/js": "^10.0.1",
    "eslint": "^10.0.1",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-native": "^5.0.0",
    "globals": "^17.3.0",
    "husky": "^9.1.7",
    "lint-staged": "^16.2.7",
    "prettier": "^3.8.1",
    "turbo": "^2.8.10",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.56.0"
  },
  "lint-staged": {
    "*.{ts,tsx,js,jsx,mjs,cjs}": [
      "eslint --fix",
      "prettier --write"
    ],
    "*.{json,css,md,yaml,yml}": [
      "prettier --write"
    ]
  }
}
